# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA_DEBUG=false

# AdSense 뉴스 기사용 광고 슬롯 ID (선택). 없으면 광고 미렌더.
NEXT_PUBLIC_ADSENSE_NEWS_SLOT=

# Amplitude Product Analytics — leave blank to disable (completely inert without a key).
# Get your API key from https://app.amplitude.com → Settings → Projects → API Keys.
NEXT_PUBLIC_AMPLITUDE_API_KEY=

# Google Search Console 소유권 확인 토큰 (선택). 값이 있으면 <meta name="google-site-verification"> 출력.
GOOGLE_SITE_VERIFICATION=

# AdSense 콘텐츠 페이지(도구/상황/비교) 인피드 광고 슬롯 ID (선택). 없으면 빈 슬롯.
NEXT_PUBLIC_ADSENSE_CONTENT_SLOT=

# AdFit 광고 단위 ID — 사각형/사이드바 배너 (선택). 없으면 광고 미렌더.
NEXT_PUBLIC_ADFIT_UNIT_RECT=
NEXT_PUBLIC_ADFIT_UNIT_SKY=

# /api/indexnow, /api/subscribe 등 cron/자동화 엔드포인트 공유 시크릿 (선택이지만 프로덕션 필수).
# 값이 비어 있으면 해당 엔드포인트는 인증 없이 열려 있다 — 반드시 Vercel 프로덕션 환경에 설정할 것.
CRON_SECRET=

# Supabase 프로젝트 URL + service_role 키 — 뉴스레터 구독(subscribe)과
# trending-seed(scripts/fetch-llm-news.ts) 저장에 사용. 서버 전용, 절대 커밋 금지.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API 키 — scripts/generate-news.ts (뉴스 다이제스트 자동 생성)에서 사용.
ANTHROPIC_API_KEY=
