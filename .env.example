# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA_DEBUG=false

# AdSense 뉴스 기사용 광고 슬롯 ID (선택). 없으면 광고 미렌더.
NEXT_PUBLIC_ADSENSE_NEWS_SLOT=

# Amplitude Product Analytics — leave blank to disable (completely inert without a key).
# Get your API key from https://app.amplitude.com → Settings → Projects → API Keys.
NEXT_PUBLIC_AMPLITUDE_API_KEY=

# Google Search Console 소유권 확인 토큰 (선택). 값이 있으면 <meta name="google-site-verification"> 출력.
GOOGLE_SITE_VERIFICATION=
